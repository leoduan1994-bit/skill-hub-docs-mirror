# ============ AI 视频生成工具 配置 ============
# 复制本文件为 .env 并填入你的值：  cp .env.example .env

# Replicate API Token（必填，真实生成时需要）
# 获取地址： https://replicate.com/account/api-tokens
# 不填则自动进入「演示模式」（浏览器本地合成占位视频，无需联网）
REPLICATE_API_TOKEN=

# 服务端口（可选，默认 3000）
PORT=3000

# 默认模型（可选），可选值见 server.js 中的 MODELS：
#   minimax/video-01
#   kwaivgi/kling-v1.6-standard
#   bytedance/seedance-1-lite
DEFAULT_MODEL=minimax/video-01
